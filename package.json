{
  "name": "dc-lol-bot",
  "version": "1.0.0",
  "description": "Discord League of Legends stats bot",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:api": "node --watch src/api/server.js",
    "dev:web": "concurrently -n API,React -c cyan,magenta \"npm run dev:api\" \"cd web && npm run dev\""
  },
  "dependencies": {
    "discord.js": "^14",
    "axios": "^1.6.0",
    "better-sqlite3": "^9.4.3",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
